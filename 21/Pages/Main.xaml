<Page x:Class="_21.Pages.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:_21.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">

    <Grid>
        <Grid
            Height="50"
            VerticalAlignment="Top"
            Background="#FFA0A0A0">
            <Image
                Width="30"
                Height="30"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="10" Source="/Image/icon.png"/>
            <Label
                VerticalAlignment="Top"
                Foreground="White"
                Content="Учет входящих и исходящих документов"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                FontSize="20"
                FontWeight="Bold" Height="40"/>
            <Button
                Click="Exit"
                Content="Выйти"
                Width="75"
                Height="25"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="10"
                Background="White"/>
        </Grid>

        <ScrollViewer Margin="10,55,10,40">
            <StackPanel x:Name="Parent"/>
        </ScrollViewer>

        <Button
            Click="Add"
            Content="Добавить"
            Width="75"
            Height="25"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Left"
            Margin="10"
            Background="White"/>
    </Grid>
</Page>
